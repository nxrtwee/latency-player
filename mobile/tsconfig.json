{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["../src/renderer/src/*"],
      "@shared/*": ["../src/shared/*"],
      "@mobile/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "../src/shared/**/*"]
}
